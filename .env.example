# Copy this to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# OCI Generative AI
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..your-compartment-id
OCI_REGION=uk-london-1
OCI_GENAI_MODEL_ID=cohere.command-r-plus
OCI_EMBED_MODEL_ID=cohere.embed-english-v3.0
OCI_CONFIG_PATH=~/.oci/config
OCI_CONFIG_PROFILE=DEFAULT

# Autonomous Database
ADB_USER=sql_agent_readonly
ADB_PASSWORD=replace-me
ADB_DSN=your-db-name_high
ADB_WALLET_LOCATION=./wallet
SELECT_AI_PROFILE=your-select-ai-profile

# Agent behaviour
AGENT_MAX_RETRIES=3
AGENT_DB_CONNECT_RETRIES=6
AGENT_QUERY_TIMEOUT_SECONDS=15
AGENT_MAX_ROWS_RETURNED=500
RAG_AUTO_SEED_ON_STARTUP=false

# Vector fallback — retrieve similar rows when generated SQL returns 0 rows
VECTOR_FALLBACK_ENABLED=true
VECTOR_FALLBACK_TOP_K=5

# Demo fallback — serve cached results if the live DB or OCI is unreachable
# Keep this OFF in dev; flip it ON only just before the live demo.
DEMO_FALLBACK_ENABLED=false
DEMO_CACHE_PATH=./evaluation/datasets/demo_cache.json

# Schema obfuscation — mask real table/column names before sending to LLM
SCHEMA_OBFUSCATION_ENABLED=true

# Dynamic few-shot injection — pull similar past queries from the vector store
FEW_SHOT_ENABLED=true
FEW_SHOT_K=2

# Multi-model routing — send simple queries to a cheaper/faster model
ROUTER_ENABLED=true
ROUTER_SMALL_MODEL_ID=cohere.command-r
ROUTER_LARGE_MODEL_ID=cohere.command-r-plus

# Critic confidence — UI shows a warning below this threshold
CONFIDENCE_WARNING_THRESHOLD=0.7

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
