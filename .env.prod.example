# ============================================================================
# IADS Agentic SQL Agent - Production Environment Configuration
# ============================================================================
# Copy this file to .env.prod and fill in your actual values
# Never commit .env.prod to version control!

# ============================================================================
# API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# CORS - allowed origins for frontend
ALLOWED_ORIGINS=http://localhost:8501,https://yourdomain.com

# ============================================================================
# Frontend Configuration
# ============================================================================
API_URL=http://localhost:8000
FRONTEND_PORT=8501

# ============================================================================
# Monitoring Configuration
# ============================================================================
MONITORING_PORT=8502

# ============================================================================
# Oracle Autonomous Database (OCI)
# ============================================================================
# Database connection
ADB_USER=ADMIN
ADB_PASSWORD=<your-adb-password>
ADB_DSN=hackatondb_high
ADB_WALLET_LOCATION=/app/wallet

# Wallet credentials
ADB_WALLET_PASSWORD=<your-wallet-password>

# ============================================================================
# OCI Credentials
# ============================================================================
# Path to OCI config directory (contains .oci directory with credentials)
OCI_CONFIG_PATH=/app/.oci

# OCI region (e.g., us-ashburn-1, eu-frankfurt-1)
OCI_REGION=us-ashburn-1

# OCI compartment ID for Generative AI
OCI_COMPARTMENT_ID=<your-compartment-id>

# OCI config profile name
OCI_CONFIG_PROFILE=DEFAULT

# ============================================================================
# OCI Generative AI Models
# ============================================================================
# SQL generation model
OCI_GENAI_MODEL_ID=meta.llama-3.3-70b-instruct

# Embedding model for RAG
OCI_EMBED_MODEL_ID=cohere.embed-english-v3.0

# ============================================================================
# Agent Behavior
# ============================================================================
# Maximum number of retries for failed queries
AGENT_MAX_RETRIES=3

# Query timeout in seconds
AGENT_QUERY_TIMEOUT_SECONDS=15

# Maximum rows to return
AGENT_MAX_ROWS_RETURNED=500

# ============================================================================
# Feature Flags
# ============================================================================
# Enable vector database fallback
VECTOR_FALLBACK_ENABLED=true

# Enable demo mode with cached results
DEMO_FALLBACK_ENABLED=false

# Enable few-shot learning in prompts
FEW_SHOT_ENABLED=true

# ============================================================================
# Security
# ============================================================================
# Rate limiting: max requests per minute
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================================
# Docker/Deployment
# ============================================================================
# Container restart policy
RESTART_POLICY=unless-stopped

# ============================================================================
# Monitoring & Logging
# ============================================================================
# Log file location
LOG_FILE_PATH=logs/agent.log

# Metrics file location
METRICS_FILE_PATH=logs/metrics.jsonl

# ============================================================================
# Production Safety Checks
# ============================================================================
# Set to 'production' to enable strict mode
ENVIRONMENT=production
